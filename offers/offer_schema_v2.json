{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prompt03OfferRecord",
  "type": "object",
  "required": [
    "offer_id",
    "vendor_name",
    "vendor_country",
    "offer_name",
    "source_url",
    "source_type",
    "claim_type",
    "retrieved_at",
    "evidence_refs",
    "offer_kind",
    "market_side",
    "problem_domain",
    "workflow_solved",
    "required_device_connectivity",
    "required_digital_maturity",
    "pricing_model",
    "minimum_budget_band",
    "implementation_friction",
    "onboarding_burden",
    "trust_barrier",
    "language_support",
    "integration_demands",
    "regulatory_sensitivity",
    "expected_roi_path",
    "evidence_strength",
    "channel_model",
    "substitute_cluster",
    "support_burden",
    "vendor_durability",
    "deployability"
  ],
  "properties": {
    "offer_id": {"type": "string"},
    "vendor_name": {"type": "string"},
    "vendor_country": {"type": "string", "minLength": 2, "maxLength": 2},
    "offer_name": {"type": "string"},
    "source_url": {"type": "string"},
    "source_type": {"type": "string"},
    "claim_type": {"enum": ["FACT", "INFERENCE", "TBD"]},
    "retrieved_at": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "offer_kind": {"enum": ["candidate", "local_substitute", "national_substitute", "international_benchmark"]},
    "market_side": {"enum": ["b2c", "b2b", "both"]},
    "target_market": {"type": "string"},
    "target_user_type": {"type": "string"},
    "problem_domain": {"type": "string"},
    "workflow_solved": {"type": "string"},
    "input_requirements": {"type": "array", "items": {"type": "string"}},
    "required_device_connectivity": {"type": "string"},
    "required_digital_maturity": {"type": "string"},
    "pricing_model": {"type": "string"},
    "pricing_visibility": {"type": "string"},
    "minimum_budget_band": {"type": "string"},
    "minimum_budget_lkr": {"type": "number"},
    "implementation_friction": {"type": "string"},
    "onboarding_burden": {"type": "string"},
    "trust_barrier": {"type": "string"},
    "language_support": {"type": "array", "items": {"type": "string"}},
    "language_demands": {"type": "string"},
    "integration_demands": {"type": "string"},
    "regulatory_sensitivity": {"type": "string"},
    "expected_roi_path": {"type": "string"},
    "roi_visibility": {"type": "string"},
    "evidence_strength": {"type": "integer", "minimum": 0, "maximum": 100},
    "channel_model": {"type": "string"},
    "substitute_cluster": {"type": "string"},
    "support_burden": {"type": "string"},
    "vendor_durability": {"type": "string"},
    "deployability": {"type": "string"},
    "notes": {"type": "string"}
  }
}
