{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prompt #02 Curated Offer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "offer_id",
    "vendor_name",
    "vendor_country",
    "offer_name",
    "target_segment",
    "problem_domain",
    "pricing_model",
    "source_url",
    "claim_type",
    "retrieved_at",
    "evidence_refs"
  ],
  "properties": {
    "offer_id": { "type": "string", "minLength": 1 },
    "vendor_name": { "type": "string", "minLength": 1 },
    "vendor_country": { "type": "string", "minLength": 2, "maxLength": 2 },
    "offer_name": { "type": "string", "minLength": 1 },
    "target_segment": { "type": "string", "enum": ["b2c", "b2b_sme", "b2b_enterprise", "hybrid"] },
    "target_user_type": { "type": "string" },
    "problem_domain": { "type": "string" },
    "workflow_solved": { "type": "string" },
    "input_requirements": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "required_device_connectivity": { "type": "string" },
    "required_digital_maturity": { "type": "string", "enum": ["low", "medium", "high"] },
    "pricing_model": { "type": "string", "enum": ["subscription", "usage_based", "project_fee", "custom_quote"] },
    "minimum_budget_band": { "type": "string" },
    "deployment_friction": { "type": "string", "enum": ["low", "medium", "high"] },
    "trust_barrier": { "type": "string", "enum": ["low", "medium", "high"] },
    "language_support": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "language_demands": { "type": "string", "enum": ["low", "medium", "high"] },
    "integration_demands": { "type": "string", "enum": ["low", "medium", "high"] },
    "regulatory_sensitivity": { "type": "string", "enum": ["low", "medium", "high"] },
    "expected_roi_path": { "type": "string" },
    "evidence_strength": { "type": "integer", "minimum": 0, "maximum": 100 },
    "market_side": { "type": "string", "enum": ["b2c", "b2b", "both"] },
    "channel_model": { "type": "string" },
    "local_substitute_pressure": { "type": "string", "enum": ["low", "medium", "high"] },
    "implementation_motion": { "type": "string" },
    "notes": { "type": "string" },
    "source_url": { "type": "string", "format": "uri" },
    "source_type": { "type": "string" },
    "claim_type": { "type": "string", "enum": ["FACT", "INFERENCE", "TBD"] },
    "retrieved_at": { "type": "string", "format": "date-time" },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
